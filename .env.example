# --- AI tutor (optional locally) ---
# The tutor route uses the Vercel AI Gateway. Without a key, /api/explain
# returns a deterministic, fact-only fallback and the rest of the app works.
AI_GATEWAY_API_KEY=

# Optional: model id routed through the AI Gateway (default: openai/gpt-4o-mini).
TUTOR_MODEL=openai/gpt-4o-mini
